# COGNOSCERE BookSummarizer Configuration
# Copy this file to .env and fill in your values

# Kimi API Key (required)
# Get yours at: https://kimi.com/code/console
KIMI_API_KEY=sk-kimi-YOUR_API_KEY_HERE

# Kimi API Settings (usually no need to change)
KIMI_BASE_URL=https://api.kimi.com/coding/v1
KIMI_MODEL=kimi-k2.5

# Source directory for ebooks (optional - can also set in web UI)
# EBOOK_SOURCE_DIR=/path/to/your/ebooks
