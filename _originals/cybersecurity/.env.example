# Cybersec Knowledge Base - Environment Configuration
# Copy this file to .env and fill in your values

# === Application ===
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
LOG_LEVEL=INFO

# === Threat Intelligence API Keys (Optional) ===
# OTX (AlienVault Open Threat Exchange) - Free
OTX_API_KEY=

# VirusTotal - Free tier available
VIRUSTOTAL_API_KEY=

# Shodan - Free tier available
SHODAN_API_KEY=

# === Security Settings ===
CORS_ORIGINS=["http://localhost:3000","https://heyibnu.com"]
RATE_LIMIT_PER_MINUTE=60
